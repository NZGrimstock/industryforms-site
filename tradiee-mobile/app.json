{
  "expo": {
    "name": "IndustryForms",
    "slug": "industryforms",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "industryforms",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f9fafb"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.industryforms.app"
    },
    "android": {
      "package": "com.industryforms.app",
      "minSdkVersion": 26,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f97316"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.NFC",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@stripe/stripe-terminal-react-native",
        {
          "appDelegate": true,
          "tapToPayCheck": true,
          "locationWhenInUsePermission": "IndustryForms uses your location to connect to Tap to Pay and card readers.",
          "bluetoothAlwaysUsagePermission": "IndustryForms uses Bluetooth to connect to supported card readers.",
          "bluetoothPeripheralPermission": "IndustryForms uses Bluetooth to connect to supported card readers.",
          "localNetworkUsagePermission": "IndustryForms uses the local network to connect to supported Stripe readers."
        }
      ],
      [
        "@journeyapps/react-native-quick-sqlite",
        {
          "enableSQLCipher": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "IndustryForms tracks your location in the background to automatically log travel for your vehicle logbook.",
          "locationWhenInUsePermission": "IndustryForms uses your location to track travel for your vehicle logbook.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "IndustryForms needs access to your photos to attach images to jobs.",
          "cameraPermission": "IndustryForms needs your camera to take job photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "915226c0-d94f-4554-a829-a17fe93c5748"
      }
    },
    "owner": "grimstock"
  }
}
